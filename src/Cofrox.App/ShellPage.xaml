<Page
    x:Class="Cofrox.App.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <NavigationView x:Name="RootNavigationView"
                    IsBackButtonVisible="Collapsed"
                    IsPaneToggleButtonVisible="True"
                    PaneDisplayMode="LeftCompact"
                    SelectionChanged="NavigationView_SelectionChanged">
        <NavigationView.Header>
            <TextBlock Text="Cofrox" />
        </NavigationView.Header>

        <NavigationView.MenuItems>
            <NavigationViewItem Content="Home" Tag="home">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Home" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Formats" Tag="formats">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="AllApps" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="History" Tag="history">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Clock" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Settings" Tag="settings">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Setting" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.Content>
            <Frame x:Name="ContentFrame" />
        </NavigationView.Content>
    </NavigationView>
</Page>
