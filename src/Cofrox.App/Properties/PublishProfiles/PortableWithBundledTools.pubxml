<?xml version="1.0" encoding="utf-8"?>
<!-- Opt-in offline tool pack publish. Review FFMPEG_COMPLIANCE.md and THIRD_PARTY_LICENSES.txt before distributing. -->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows10.0.17763.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <BundleExternalTools>true</BundleExternalTools>
    <PublishDir>$(MSBuildProjectDirectory)\..\..\artifacts\publish\Cofrox.App.WithTools\</PublishDir>
  </PropertyGroup>
</Project>
