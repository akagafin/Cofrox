<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="CofroxPaneBrush" Color="#F4F4F4" />
            <SolidColorBrush x:Key="CofroxCardBrush" Color="#F9FFFFFF" />
            <SolidColorBrush x:Key="CofroxOutlineBrush" Color="#FF00B4D8" />
            <SolidColorBrush x:Key="CofroxMutedOutlineBrush" Color="#FFB7B7B7" />
            <SolidColorBrush x:Key="LegalBadgePermissiveBrush" Color="#FFD9F99D" />
            <SolidColorBrush x:Key="LegalBadgeLgplBrush" Color="#FFFDE68A" />
            <SolidColorBrush x:Key="LegalBadgeGplBrush" Color="#FFFDBA74" />
            <SolidColorBrush x:Key="LegalBadgeAgplBrush" Color="#FFFCA5A5" />
            <SolidColorBrush x:Key="LegalBadgeCommunityBrush" Color="#FFBFDBFE" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="CofroxPaneBrush" Color="#FF1C1C1C" />
            <SolidColorBrush x:Key="CofroxCardBrush" Color="#FF272727" />
            <SolidColorBrush x:Key="CofroxOutlineBrush" Color="#FF00B4D8" />
            <SolidColorBrush x:Key="CofroxMutedOutlineBrush" Color="#FF616161" />
            <SolidColorBrush x:Key="LegalBadgePermissiveBrush" Color="#FF3F6212" />
            <SolidColorBrush x:Key="LegalBadgeLgplBrush" Color="#FFA16207" />
            <SolidColorBrush x:Key="LegalBadgeGplBrush" Color="#FF9A3412" />
            <SolidColorBrush x:Key="LegalBadgeAgplBrush" Color="#FF991B1B" />
            <SolidColorBrush x:Key="LegalBadgeCommunityBrush" Color="#FF1D4ED8" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <Color x:Key="CofroxAccentColor">#FF00B4D8</Color>
    <SolidColorBrush x:Key="CofroxAccentBrush" Color="{StaticResource CofroxAccentColor}" />
</ResourceDictionary>
