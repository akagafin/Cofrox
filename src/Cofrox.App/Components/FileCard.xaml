<UserControl
    x:Class="Cofrox.App.Components.FileCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Border x:Name="CardBorder"
            Margin="0,0,0,12"
            Padding="20"
            CornerRadius="22"
            Background="{ThemeResource CofroxCardBrush}">
        <StackPanel Spacing="14">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0"
                          FontSize="28"
                          Glyph="{Binding SourceGlyph}"
                          Foreground="{StaticResource CofroxAccentBrush}" />

                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="{Binding FileName}" TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Style="{StaticResource MonoLabelStyle}" Text="{Binding SourceExtension}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding FileSize}" />
                    </StackPanel>
                </StackPanel>

                <ComboBox Grid.Column="2"
                          Header="Target format"
                          ItemsSource="{Binding AvailableTargets}"
                          SelectedItem="{Binding SelectedTarget, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}" />
                                <TextBlock Style="{StaticResource MonoLabelStyle}" Text="{Binding Extension}" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <SplitButton Grid.Column="3"
                             Command="{Binding ConvertCommand}"
                             Content="Convert">
                    <SplitButton.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Reset to defaults" Command="{Binding ResetOptionsCommand}" />
                            <MenuFlyoutItem Text="Cancel current job" Command="{Binding CancelCommand}" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Remove from queue" Command="{Binding RemoveCommand}" />
                        </MenuFlyout>
                    </SplitButton.Flyout>
                </SplitButton>
            </Grid>

            <InfoBar IsOpen="{Binding IsInfoBarOpen}"
                     Message="{Binding InfoMessage}"
                     Severity="{Binding InfoSeverity}" />

            <ProgressBar Height="6"
                         Minimum="0"
                         Maximum="1"
                         Value="{Binding Progress}"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{Binding StatusText}"
                       Visibility="{Binding StatusText, Converter={StaticResource BoolToVisibilityConverter}}" />

            <Expander Header="Conversion Options"
                      IsExpanded="True"
                      Visibility="{Binding HasOptions, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="10">
                    <ItemsControl ItemsSource="{Binding Options}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="16"
                                      Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <Ellipse Width="8"
                                                 Height="8"
                                                 Fill="{StaticResource CofroxAccentBrush}"
                                                 Visibility="{Binding IsChanged, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="6">
                                        <ComboBox Visibility="{Binding IsChoice, Converter={StaticResource BoolToVisibilityConverter}}"
                                                  ItemsSource="{Binding Choices}"
                                                  SelectedValue="{Binding SelectedChoiceKey, Mode=TwoWay}"
                                                  SelectedValuePath="Key"
                                                  DisplayMemberPath="Label" />

                                        <StackPanel Visibility="{Binding IsSlider, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Slider Minimum="{Binding Minimum}"
                                                    Maximum="{Binding Maximum}"
                                                    StepFrequency="{Binding Step}"
                                                    Value="{Binding NumericValue, Mode=TwoWay}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       Text="{Binding NumericValue}" />
                                        </StackPanel>

                                        <NumberBox Visibility="{Binding IsNumber, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   Minimum="{Binding Minimum}"
                                                   Maximum="{Binding Maximum}"
                                                   SmallChange="{Binding Step}"
                                                   Value="{Binding NumericValue, Mode=TwoWay}" />

                                        <ToggleSwitch Visibility="{Binding IsToggle, Converter={StaticResource BoolToVisibilityConverter}}"
                                                      IsOn="{Binding BoolValue, Mode=TwoWay}" />

                                        <TextBox Visibility="{Binding IsText, Converter={StaticResource BoolToVisibilityConverter}}"
                                                 PlaceholderText="{Binding Placeholder}"
                                                 Text="{Binding TextValue, Mode=TwoWay}" />

                                        <PasswordBox Visibility="{Binding IsPassword, Converter={StaticResource BoolToVisibilityConverter}}"
                                                     Tag="{Binding}"
                                                     PasswordChanged="OptionPasswordChanged" />

                                        <ColorPicker Visibility="{Binding IsColor, Converter={StaticResource BoolToVisibilityConverter}}"
                                                     Tag="{Binding}"
                                                     ColorChanged="OptionColorChanged" />

                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Text="{Binding Description}"
                                                   TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button HorizontalAlignment="Left"
                            Command="{Binding ResetOptionsCommand}"
                            Content="Reset to defaults" />
                </StackPanel>
            </Expander>
        </StackPanel>
    </Border>
</UserControl>
