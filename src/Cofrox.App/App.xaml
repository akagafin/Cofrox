<Application
    x:Class="Cofrox.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Cofrox.App.Converters"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <muxc:XamlControlsResources />
                <ResourceDictionary Source="ms-appx:///Resources/Typography.xaml" />
                <ResourceDictionary Source="ms-appx:///Resources/ThemeResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:LegalBadgeKindToBrushConverter x:Key="LegalBadgeKindToBrushConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
