<Page
    x:Class="Cofrox.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16">
            <Expander Header="Conversion" IsExpanded="True">
                <StackPanel Spacing="14">
                    <TextBox Header="Default Output Folder"
                             Text="{Binding OutputFolderPath, Mode=TwoWay}" />
                    <Button HorizontalAlignment="Left"
                            Command="{Binding PickOutputFolderCommand}"
                            Content="Choose folder" />

                    <ComboBox Header="Default Video Quality"
                              SelectedItem="{Binding DefaultVideoQuality, Mode=TwoWay}">
                        <x:String>Low</x:String>
                        <x:String>Medium</x:String>
                        <x:String>High</x:String>
                    </ComboBox>

                    <Slider Header="Default Image Quality"
                            Minimum="50"
                            Maximum="100"
                            Value="{Binding DefaultImageQuality, Mode=TwoWay}" />

                    <ComboBox Header="Maximum Parallel Conversions"
                              SelectedIndex="{Binding MaxParallelConversions, Mode=TwoWay}">
                        <ComboBoxItem Content="Auto" />
                        <ComboBoxItem Content="1" />
                        <ComboBoxItem Content="2" />
                    </ComboBox>
                </StackPanel>
            </Expander>

            <Expander Header="Appearance" IsExpanded="True">
                <StackPanel Spacing="14">
                    <ComboBox Header="Theme"
                              SelectedItem="{Binding ThemeModeName, Mode=TwoWay}">
                        <x:String>System</x:String>
                        <x:String>Light</x:String>
                        <x:String>Dark</x:String>
                    </ComboBox>
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="System mode tracks Windows in real time through UISettings.ColorValuesChanged." />
                </StackPanel>
            </Expander>

            <Expander Header="Storage" IsExpanded="True">
                <StackPanel Spacing="14">
                    <ToggleSwitch Header="Auto-delete temp files"
                                  IsOn="{Binding AutoDeleteTempFiles, Mode=TwoWay}" />
                    <ToggleSwitch Header="Save conversion history"
                                  IsOn="{Binding SaveHistory, Mode=TwoWay}" />
                    <TextBox Header="LibreOffice Path"
                             PlaceholderText="Optional portable or installed path"
                             Text="{Binding LibreOfficePath, Mode=TwoWay}" />
                    <Button HorizontalAlignment="Left"
                            Command="{Binding ClearTempCommand}"
                            Content="Clean temp folder now" />
                </StackPanel>
            </Expander>

            <Expander Header="About" IsExpanded="True">
                <StackPanel Spacing="10">
                    <TextBlock Text="Cofrox" Style="{StaticResource SectionHeadingStyle}" />
                    <TextBlock Text="Convert anything. Leave nothing behind." />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="Built for Windows 10 1809+ and Windows 11 with WinUI 3, MVVM, SQLite, and on-device conversion engines." />
                </StackPanel>
            </Expander>

            <Expander x:Name="LegalExpander" IsExpanded="True">
                <StackPanel Spacing="12">
                    <Button HorizontalAlignment="Stretch"
                            Click="PrivacyPolicyButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Protect" />
                            <TextBlock x:Name="PrivacyPolicyText" />
                        </StackPanel>
                    </Button>

                    <Button HorizontalAlignment="Stretch"
                            Click="TermsOfUseButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Document" />
                            <TextBlock x:Name="TermsOfUseText" />
                        </StackPanel>
                    </Button>

                    <Button HorizontalAlignment="Stretch"
                            Click="LicensesButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Library" />
                            <TextBlock x:Name="LicensesText" />
                        </StackPanel>
                    </Button>

                    <Button HorizontalAlignment="Stretch"
                            Click="DisclaimerButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Help" />
                            <TextBlock x:Name="DisclaimerText" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Expander>

            <Button HorizontalAlignment="Left"
                    Command="{Binding SaveCommand}"
                    Content="Save settings" />
        </StackPanel>
    </ScrollViewer>
</Page>
