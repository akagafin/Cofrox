<Page
    x:Class="Cofrox.App.Pages.FormatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <AutoSuggestBox x:Name="SearchBox"
                        Grid.Row="0"
                        PlaceholderText="Search by extension, format name, or category"
                        Text="{Binding SearchText, Mode=TwoWay}" />

        <TeachingTip Title="Search the matrix"
                     Subtitle="Type MP4, PNG, DOCX, JSON, SRT, or ZIP to filter instantly."
                     IsOpen="{Binding IsTeachingTipOpen}"
                     Target="{Binding ElementName=SearchBox}"
                     Grid.Row="0" />

        <ComboBox Grid.Row="1"
                  Header="Category"
                  ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding SelectedCategory, Mode=TwoWay}" />

        <GridView Grid.Row="2"
                  IsItemClickEnabled="False"
                  ItemsSource="{Binding VisibleFormats}"
                  SelectionMode="None">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="18"
                            Margin="0,0,14,14"
                            Width="240"
                            CornerRadius="20"
                            Background="{ThemeResource CofroxCardBrush}">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Style="{StaticResource MonoLabelStyle}" Text="{Binding Extension}" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Category}" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource SectionHeadingStyle}" Text="{Binding DisplayName}" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{Binding Description}"
                                       TextWrapping="WrapWholeWords" />
                            <Button HorizontalAlignment="Left" Content="Supported targets">
                                <Button.Flyout>
                                    <Flyout>
                                        <StackPanel Width="220" Spacing="10">
                                            <TextBlock Style="{StaticResource SectionHeadingStyle}" Text="{Binding DisplayName}" />
                                            <TextBlock Text="{Binding Description}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Style="{StaticResource MonoLabelStyle}" Text="{Binding Extension}" />
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
